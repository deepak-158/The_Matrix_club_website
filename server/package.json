{
    "name": "matrix-club-api",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "wrangler dev",
        "deploy": "wrangler deploy",
        "db:migrate": "wrangler d1 execute matrix-club-db --file=./schema.sql",
        "db:migrate:local": "wrangler d1 execute matrix-club-db --file=./schema.sql --local",
        "db:seed": "wrangler d1 execute matrix-club-db --file=./seed.sql",
        "db:seed:local": "wrangler d1 execute matrix-club-db --file=./seed.sql --local"
    },
    "dependencies": {
        "hono": "^4.6.0"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20241106.0",
        "wrangler": "^3.91.0"
    }
}